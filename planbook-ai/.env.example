# Environment Variables - PlanbookAI
# Copy file này thành .env và điền giá trị thực

# ===== GEMINI AI =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ===== JWT =====
# QUAN TRỌNG: Đổi key này trước khi deploy production!
JWT_SECRET=planbook-super-secret-key-change-in-production-min-32-chars

# ===== DATABASE =====
MYSQL_ROOT_PASSWORD=root123
MYSQL_USER=planbook
MYSQL_PASSWORD=planbook123
